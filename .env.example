# Prompt generation from PDFs
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
PROMPT_OUTPUT_LANGUAGE=English
PROMPT_MAX_OUTPUT_TOKENS=8192

# Code generation
# Supported values include: gemini, openai_compatible, zai
CODEGEN_PROVIDER=openai_compatible
CODEGEN_API_KEY=
CODEGEN_BASE_URL=
CODEGEN_MODEL=
CODEGEN_TEMPERATURE=0.2
CODEGEN_MAX_OUTPUT_TOKENS=65536

# Optional vendor-specific keys for OpenAI-compatible providers
OPENAI_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=

# Optional OpenAI-compatible request customization
CODEGEN_EXTRA_BODY={}
CODEGEN_USE_RESPONSES=false

# VLM judge
OPENAI_VLM_MODEL=gpt-4.1
OPENAI_VLM_TRIALS=3
OPENAI_VLM_LAST_K_PER_MODULE=4
